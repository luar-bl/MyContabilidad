@page "/resumen-graficos"
@using ProyectoCasa.Components.General
@rendermode InteractiveServer
@attribute [Authorize]

<Menu/>

<MudContainer Style="margin-top: 90px;">
    <MudCard>
        <MudCardContent>
            <MudText Typo="Typo.h5">Ingresos 💸​</MudText>
            <MudChart ChartType="MudBlazor.ChartType.Donut"
                      Height="150px"
                      ChartSeries="@LstIngresos.AsChartDataSet()"
                      ChartLabels="@LstNombreCasa"
                      LegendPosition="MudBlazor.Position.Bottom" />
        </MudCardContent>
    </MudCard>
    <MudCard>
        <MudCardContent>
            <MudText Typo="Typo.h5">Gastos 💳</MudText>
            <MudChart ChartType="MudBlazor.ChartType.Donut"
                      Height="150px"
                      ChartSeries="@LstGastos.AsChartDataSet()"
                      ChartLabels="@LstTipoFactura"
                      LegendPosition="MudBlazor.Position.Bottom" />
        </MudCardContent>
    </MudCard>
    <MudCard>
        <MudCardContent>
            <MudText Typo="Typo.h5">Ahorros 📈</MudText>
            <MudChart ChartType="MudBlazor.ChartType.Donut"
                      Height="150px"
                      ChartSeries="@LstAhorros.AsChartDataSet()"
                      ChartLabels="@LstNombreCasa"
                      LegendPosition="MudBlazor.Position.Bottom" />
        </MudCardContent>
    </MudCard>
