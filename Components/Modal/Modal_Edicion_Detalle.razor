<MudDialog>
    <TitleContent>
        Editar Detalle
    </TitleContent>
    <DialogContent>
        @if (DetalleCasa != null)
        {
            <MudItem xs="12" md="6">
                <MudGrid>
                    <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="DetalleCasa.Descripcion"
                                        Label="Descripción 📋"
                                        Variant="Variant.Outlined"
                                        Margin="Margin.Normal"
                                        For="@(() => DetalleCasa.Descripcion)"
                                        AutoFocus="true"/>
                    </MudItem>
                    <MudItem xs="12" md="8">
                        <MudTextField @bind-Value="DetalleCasa.Cantidad"
                                        Label="Cantidad 🤏"
                                        Variant="Variant.Outlined"
                                        Margin="Margin.Normal"
                                        For="@(() => DetalleCasa.Cantidad)"/>
                    </MudItem>
                    <MudItem xs="12" md="8">
                        <MudTextField @bind-Value="DetalleCasa.Fecha"
                                        Label="Fecha 📅"
                                        Variant="Variant.Outlined"
                                        Margin="Margin.Normal"
                                        For="@(() => DetalleCasa.Fecha)"/>
                    </MudItem>
                </MudGrid>
            </MudItem>
        }

        @if (DetalleFactura != null)
        {
            <MudItem xs="12" md="6">
                <MudGrid>
                    <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="DetalleFactura.Producto"
                                      Label="Producto 📋"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Normal"
                                      For="@(() => DetalleFactura.Producto)"
                                      AutoFocus="true" />
                    </MudItem>
                    <MudItem xs="12" md="8">
                        <MudTextField @bind-Value="DetalleFactura.Precio"
                                      Label="Precio 💶"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Normal"
                                      For="@(() => DetalleFactura.Precio)" />
                    </MudItem>
                    <MudItem xs="12" md="8">
                        <MudTextField @bind-Value="DetalleFactura.Cantidad"
                                      Label="Cantidad 🤏"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Normal"
                                      For="@(() => DetalleFactura.Cantidad)" />
                    </MudItem>
                </MudGrid>
            </MudItem>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cerrar">Salir</MudButton>
        <MudButton Color="Color.Primary" OnClick="GuardarDatos">Guardar</MudButton>
    </DialogActions>
        
</MudDialog>
