
@if(Visible)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edición Det</h5>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="Cerrar"></button>
                </div>
                <div class="modal-body">

                    @if (DetalleCasa != null)
    {
                        <div class="mb-3">
                            <label for="Descripcion" class="form-label">Descripción: </label>
                            <input class="form-control" type="text" @bind-value="DetalleCasa.Descripcion" placeholder="Descripcion" />
                         </div>
                        <div class="mb-3">
                            <label for="Cantidad" class="form-label">Cantidad: </label>
                            <input class="form-control" type="number" @bind-value="DetalleCasa.Cantidad" placeholder="Cantidad" />
                        </div>
                        <div class="mb-3">
                            <label for="Fecha" class="form-label">Fecha: </label>
                            <input class="form-control" type="text" @bind-value="DetalleCasa.Fecha" placeholder="Fecha" />
                        </div>
                    }


                    @if (DetalleFactura != null)
                    {
                        <div class="mb-3">
                            <label for="Producto" class="form-label">Producto: </label>
                            <input class="form-control" type="text" @bind-value="DetalleFactura.Producto" placeholder="Producto" />
                        </div>
                        <div class="mb-3">
                            <label for="Precio" class="form-label">Precio: </label>
                            <input class="form-control" type="number" @bind-value="DetalleFactura.Precio" placeholder="Precio" />
                        </div>
                        <div class="mb-3">
                            <label for="Cantidad" class="form-label">Cantidad: </label>
                            <input class="form-control" type="number" @bind-value="DetalleFactura.Cantidad" placeholder="Cantidad" />
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="Cerrar">Cerrar</button>
                    <button type="button" class="btn btn-primary" @onclick="GuardarDatos">¡Guardar cambios!</button>
                </div>
            </div>
        </div>
    </div>
}
